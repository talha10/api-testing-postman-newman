    {
      "name": "5. PUT Update User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Validate updated payload fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    var reqData = JSON.parse(pm.request.body.raw);",
              "    pm.expect(jsonData.name).to.eql(reqData.name);",
              "    pm.expect(jsonData.job).to.eql(reqData.job);",
              "});",
              "pm.test(\"UpdatedAt field exists\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.updatedAt).to.not.be.undefined;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
